<div data-controller="session">

  <h1>Lecture en cours</h1>

  <div class="reading-text-block">
    <h2><%= @reading_text.title %></h2>
    <%= simple_format(@reading_text.content) %>
  </div>

  <p>Temps écoulé : <span data-session-target="timer">0</span> secondes</p>

  <p id="status">En attente de la voix de l'élève…</p>

  <%= form_with url: "/sessions/stop", method: :post, data: { turbo: false }, html: { id: "stop-form" } do %>
    <%= hidden_field_tag :session_id, @session.id %>
    <%= hidden_field_tag :duration_seconds, 0, data: { session_target: "duration" } %>
    <%= hidden_field_tag :aborted, false, data: { session_target: "aborted" } %>
    <%= hidden_field_tag :audio_file, "", id: "audio-file-field" %>

    <button type="button" id="start-button" data-action="click->session#startRecording">
      🎤 Démarrer
    </button>

    <button type="button" id="stop-button" data-action="click->session#manualStop" disabled>
      ❌ Arrêter
    </button>

    <button type="button" id="finish-button" data-action="click->session#finishManually" style="display:none;">
      ✅ Terminer
    </button>
  <% end %>

</div>